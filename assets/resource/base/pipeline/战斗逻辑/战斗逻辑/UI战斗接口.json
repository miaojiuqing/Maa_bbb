        "recognition": "TemplateMatch",
        "template": [
            "进入游戏/剧情跳过.png"
        ],
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    342,
                    319,
                    554,
                    156
                ]
            }
        }
