            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    0,
                    143,
                    145
                ],
                "template": [
                    "战斗相关/战中检查/战斗中.png"
                ]
            }
        },
        //动作用E佬框架编写的的战斗逻辑
        //动作IDFRole.py会识别后自己加进来
        "next": [
            "[JumpBack]战斗逻辑-战斗中",
            "战斗逻辑"
        ]
    },
    "战斗逻辑-识别人物": {
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "IDFRole"
            }
        }
    },
    /////////////////////////////////////////////////////////////////////////////////////////////////////////////////
    "战斗逻辑-非战斗": {
        "next": [
            "[JumpBack]战斗逻辑-剧情中",
