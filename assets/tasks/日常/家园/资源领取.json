{
    "task": [
        {
            "name": "家园资源领取",
            "default_check": true,
            "entry": "进入家园领取金币/体力-开始任务层",
            "pipeline_override": {},
            "option": [
                "是否检查并领取所有溢出体力",
                "识别到返回要怎么做"
            ],
            "description": "活跃玩家可关闭体力领取，快几秒"
        }
    ],
    "option": {
        "是否检查并领取所有溢出体力": {
            "type": "switch",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "家园资源领取-没有可领取金币了": {
                            "next": [
                                "家园资源领取-多余体力领取流程",
                                "[JumpBack]家园资源领取-点击打开体力补充界面"
                            ]
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "家园资源领取-没有可领取金币了": {
                            "next": [
                                "成功进入游戏主菜单",
                                "[JumpBack]点击叉叉",
                                "[JumpBack]家园处-点击返回",
                                "[JumpBack]点击返回主菜单",
                                "[JumpBack]家园资源领取-点击打开体力补充界面"
                            ]
                        }
                    }
                }
            ]
        },
        "识别到返回要怎么做": {
            "type": "select",
            "cases": [
                {
                    "name": "正常点击",
                    "pipeline_override": {
                        "家园处-点击返回": {
                            "action": "Click"
                        }
                    }
                },
                {
                    "name": "尝试输入ESC键码-模拟器用户禁选",
                    "pipeline_override": {
                        "家园处-点击返回": {
                            "action": "ClickKey",
                            "key": [
                                27
                            ]
                        }
                    }
                }
            ],
            "default_case": "正常点击"
        }
    }
}
